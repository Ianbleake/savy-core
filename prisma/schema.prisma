generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ─── Profile ──────────────────────────────────────────────────────────
// User profile — linked by authId (UUID from Supabase JWT sub claim)
model Profile {
  id             String   @id @default(uuid())
  authId         String   @unique @map("auth_id")
  email          String   @unique
  firstName      String?  @map("first_name")
  lastName       String?  @map("last_name")
  secondLastName String?  @map("second_last_name")
  avatarUrl      String?  @map("avatar_url")
  phone          String?
  currency       String   @default("MXN")
  locale         String   @default("es-MX")
  timezone       String   @default("America/Mexico_City")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  accounts     Account[]
  categories   Category[]
  budgets      Budget[]
  savingsGoals SavingsGoal[]

  @@map("profiles")
}

// ─── Account ─────────────────────────────────────────────────────────
enum AccountType {
  BANK
  CREDIT
  LOAN
}

model Account {
  id        String      @id @default(uuid())
  profileId String      @map("profile_id")
  name      String
  type      AccountType
  currency  String      @default("MXN")
  balance   Decimal     @default(0) @db.Decimal(12, 2)
  color     String?
  icon      String?
  isActive  Boolean     @default(true) @map("is_active")
  createdAt DateTime    @default(now()) @map("created_at")
  updatedAt DateTime    @updatedAt @map("updated_at")

  profile      Profile       @relation(fields: [profileId], references: [id], onDelete: Cascade)
  transactions Transaction[]
  creditCard   CreditCard?
  loan         Loan?

  @@map("accounts")
}

// ─── Transaction ─────────────────────────────────────────────────────
enum TransactionType {
  INCOME
  EXPENSE
  TRANSFER
  PAYMENT
}

model Transaction {
  id          String          @id @default(uuid())
  accountId   String          @map("account_id")
  categoryId  String?         @map("category_id")
  type        TransactionType
  amount      Decimal         @db.Decimal(12, 2)
  description String?
  note        String?
  date        DateTime        @default(now())
  createdAt   DateTime        @default(now()) @map("created_at")
  updatedAt   DateTime        @updatedAt @map("updated_at")

  account  Account   @relation(fields: [accountId], references: [id], onDelete: Cascade)
  category Category? @relation(fields: [categoryId], references: [id], onDelete: SetNull)

  @@index([accountId, date])
  @@index([categoryId])
  @@map("transactions")
}

// ─── Category ────────────────────────────────────────────────────────
enum CategoryType {
  INCOME
  EXPENSE
}

model Category {
  id        String       @id @default(uuid())
  profileId String       @map("profile_id")
  name      String
  type      CategoryType
  color     String?
  icon      String?
  createdAt DateTime     @default(now()) @map("created_at")

  profile      Profile       @relation(fields: [profileId], references: [id], onDelete: Cascade)
  transactions Transaction[]
  budgets      Budget[]

  @@unique([profileId, name, type])
  @@map("categories")
}

// ─── Budget ──────────────────────────────────────────────────────────
enum BudgetPeriod {
  WEEKLY
  BIWEEKLY
  MONTHLY
  YEARLY
}

model Budget {
  id         String       @id @default(uuid())
  profileId  String       @map("profile_id")
  categoryId String       @map("category_id")
  amount     Decimal      @db.Decimal(12, 2)
  period     BudgetPeriod @default(MONTHLY)
  startDate  DateTime     @map("start_date")
  endDate    DateTime?    @map("end_date")
  isActive   Boolean      @default(true) @map("is_active")
  createdAt  DateTime     @default(now()) @map("created_at")
  updatedAt  DateTime     @updatedAt @map("updated_at")

  profile  Profile  @relation(fields: [profileId], references: [id], onDelete: Cascade)
  category Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@map("budgets")
}

// ─── Savings Goal ────────────────────────────────────────────────────
model SavingsGoal {
  id            String    @id @default(uuid())
  profileId     String    @map("profile_id")
  name          String
  targetAmount  Decimal   @map("target_amount") @db.Decimal(12, 2)
  currentAmount Decimal   @default(0) @map("current_amount") @db.Decimal(12, 2)
  deadline      DateTime?
  color         String?
  isCompleted   Boolean   @default(false) @map("is_completed")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  profile Profile @relation(fields: [profileId], references: [id], onDelete: Cascade)

  @@map("savings_goals")
}

// ─── Credit Card ─────────────────────────────────────────────────────
model CreditCard {
  id               String   @id @default(uuid())
  accountId        String   @unique @map("account_id")
  creditLimit      Decimal  @map("credit_limit") @db.Decimal(12, 2)
  cutDay           Int      @map("cut_day") // 1-31
  paymentDay       Int      @map("payment_day") // 1-31
  interestRate     Decimal  @map("interest_rate") @db.Decimal(5, 4) // annual rate as decimal (e.g. 0.3600 = 36%)
  noInterestMonths Int      @default(0) @map("no_interest_months")
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  account    Account         @relation(fields: [accountId], references: [id], onDelete: Cascade)
  statements CardStatement[]

  @@map("credit_cards")
}

// ─── Card Statement ──────────────────────────────────────────────────
model CardStatement {
  id                String   @id @default(uuid())
  creditCardId      String   @map("credit_card_id")
  periodStart       DateTime @map("period_start")
  periodEnd         DateTime @map("period_end")
  balance           Decimal  @db.Decimal(12, 2)
  minPayment        Decimal  @map("min_payment") @db.Decimal(12, 2)
  noInterestPayment Decimal  @map("no_interest_payment") @db.Decimal(12, 2)
  interestAmount    Decimal  @default(0) @map("interest_amount") @db.Decimal(12, 2)
  isPaid            Boolean  @default(false) @map("is_paid")
  createdAt         DateTime @default(now()) @map("created_at")

  creditCard CreditCard @relation(fields: [creditCardId], references: [id], onDelete: Cascade)

  @@index([creditCardId, periodEnd])
  @@map("card_statements")
}

// ─── Loan ────────────────────────────────────────────────────────────
model Loan {
  id             String   @id @default(uuid())
  accountId      String   @unique @map("account_id")
  principal      Decimal  @db.Decimal(12, 2)
  interestRate   Decimal  @map("interest_rate") @db.Decimal(5, 4) // annual rate as decimal
  termMonths     Int      @map("term_months")
  startDate      DateTime @map("start_date")
  monthlyPayment Decimal  @map("monthly_payment") @db.Decimal(12, 2)
  remaining      Decimal  @db.Decimal(12, 2)
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  account Account @relation(fields: [accountId], references: [id], onDelete: Cascade)

  @@map("loans")
}
